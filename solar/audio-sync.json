      "timing": [
        {
          "type": "SentenceBoundary",
          "offset": 0.1,
          "duration": 4.2989584,
          "text": "太陽から、太陽系の旅を始めましょう。"
        },
        {
          "type": "SentenceBoundary",
          "offset": 4.3489584,
          "duration": 3.3333334,
          "text": "太陽は私たちの恒星です。"
        },
        {
          "type": "SentenceBoundary",
          "offset": 7.6822918,
          "duration": 8.3072918,
          "text": "高温のプラズマでできた輝く球体で、その重力がすべての惑星を軌道につなぎとめています。"
        },
        {
          "type": "SentenceBoundary",
          "offset": 15.9895836,
          "duration": 3.8020834,
          "text": "太陽に最も近いのは水星です。"
        },
        {
          "type": "SentenceBoundary",
          "offset": 19.7916671,
          "duration": 7.3697918,
          "text": "最も小さな惑星で、強烈な熱と長い寒い夜のあいだを素早く進みます。"
        },
        {
          "type": "SentenceBoundary",
          "offset": 27.1614589,
          "duration": 2.4348958,
          "text": "次は金星です。"
        },
        {
          "type": "SentenceBoundary",
          "offset": 29.5963548,
          "duration": 7.3046876,
          "text": "私たちの空で明るく見え、厚い雲と強い温室効果の大気に包まれています。"
        },
        {
          "type": "SentenceBoundary",
          "offset": 36.9010424,
          "duration": 2.2526042,
          "text": "そして地球です。"
        },
        {
          "type": "SentenceBoundary",
          "offset": 39.1536467,
          "duration": 10.5338544,
          "text": "私たちの青い故郷には、液体の水、生命を支える環境、守ってくれる大気、そして一つの月があります。"
        },
        {
          "type": "SentenceBoundary",
          "offset": 49.6875011,
          "duration": 3.4505209,
          "text": "地球の外側には火星があります。"
        },
        {
          "type": "SentenceBoundary",
          "offset": 53.138022,
          "duration": 8.3854168,
          "text": "赤い惑星には、砂嵐、古い川の跡、そして太陽系で最も高い火山があります。"
        },
        {
          "type": "SentenceBoundary",
          "offset": 61.5234388,
          "duration": 3.5546875,
          "text": "さらに外側には木星があります。"
        },
        {
          "type": "SentenceBoundary",
          "offset": 65.0781264,
          "duration": 8.0208335,
          "text": "最大の惑星で、縞模様の雲、巨大な嵐、そして多くの衛星を持っています。"
        },
        {
          "type": "SentenceBoundary",
          "offset": 73.0989599,
          "duration": 3.046875,
          "text": "次に現れるのは土星です。"
        },
        {
          "type": "SentenceBoundary",
          "offset": 76.145835,
          "duration": 5.2343751,
          "text": "広い氷の環と、やわらかな金色でよく知られています。"
        },
        {
          "type": "SentenceBoundary",
          "offset": 81.3802101,
          "duration": 2.8776042,
          "text": "その次は天王星です。"
        },
        {
          "type": "SentenceBoundary",
          "offset": 84.2578143,
          "duration": 9.0234377,
          "text": "冷たい青緑色の氷巨大惑星で、大きく傾き、まるで横倒しで太陽を回っているように見えます。"
        },
        {
          "type": "SentenceBoundary",
          "offset": 93.281252,
          "duration": 4.4270834,
          "text": "主要な惑星の外縁には海王星があります。"
        },
        {
          "type": "SentenceBoundary",
          "offset": 97.7083355,
          "duration": 5.7291667,
          "text": "深い青色で風が強く、遠い暗闇の中を回っています。"
        },
        {
          "type": "SentenceBoundary",
          "offset": 103.4375023,
          "duration": 2.6171875,
          "text": "これらが太陽系です。"
        },
        {
          "type": "SentenceBoundary",
          "offset": 106.0546898,
          "duration": 10.5468752,
          "text": "一つの恒星、八つの惑星、月、環、小惑星、彗星、そして静かな軌道のリズムが共に動いています。"
        }
      ]
    },
